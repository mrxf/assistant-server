# === 服务配置 ===
PORT=4000
NODE_ENV=development

# === 数据库 ===
DATABASE_URL=file:./dev.db

# === 认证 ===
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-string-at-least-32-chars
# 首位管理员（仅 seed 脚本使用）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# === LLM - Main (对话生成) ===
AGENT_LLM_API_KEY=sk-xxx
AGENT_LLM_BASE_URL=https://your-proxy.com/v1
AGENT_LLM_MODEL=gpt-5.5

# === LLM - Hormone (情绪感知) ===
AGENT_HORMONE_LLM_API_KEY=sk-xxx
AGENT_HORMONE_LLM_BASE_URL=https://your-proxy.com/v1
AGENT_HORMONE_LLM_MODEL=gpt-5.5-mini

# === Agent 运行时 ===
AGENT_HORMONE_MODE=parallel

# 思考档位，可选：disabled / low / medium / high，默认 medium
AGENT_THINKING=medium
